auto-install-peers=false
strict-peer-dependencies=false
# pnpm v10 requires inject-workspace-packages=true by default for `pnpm deploy`.
# force-legacy-deploy restores pre-v10 behaviour (self-contained flat node_modules,
# no injection required) so `pnpm run package:mac` works on any pnpm v10.x version
# without needing the --legacy flag explicitly on the command line.
force-legacy-deploy=true
