modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "tier-review"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check-route-sizes"

[[workflows.workflow]]
name = "tier-review"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run tier-review"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "check-route-sizes"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter api-server check:routes"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 240000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 8100
externalPort = 3003

[[ports]]
localPort = 8101
externalPort = 5000

[[ports]]
localPort = 20599
externalPort = 3000

[[ports]]
localPort = 23405
externalPort = 6800
